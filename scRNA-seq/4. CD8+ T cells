# Violin plot demonstrating exhaustion, effector function, and Stemness signatures across CD8+ T cell clusters (Fig. 7c) ############
features_list <- list(
  Exhaustion = c("Pdcd1", "Tox", "Cxcl13", "Tigit", "Ctla4", "Tnfrsf9", "Havcr2", "Lag3"),
  Effector = c("Cst7", "Gzmk", "Gzma", "Nkg7", "Ifng", "Prf1", "Gzmb"),
  Stemness = c("Btla", "Foxp3", "Tnfrsf4", "Tcf7", "Eef1a1", "Sell", "Ccr7", "Il6r", "Igfbp4", "Igfl2"))

for(name in names(features_list)){
  genes <- features_list[[name]]
  genes_in_data <- genes[genes %in% rownames(CD8)]
  CD8 <- AddModuleScore(
    object = CD8,
    features = list(genes_in_data),
    ctrl = 50,
    name = paste0(name, "_Score"))}

score_names <- c("Exhaustion_Score1", "Effector_Score1", "Stemness_Score1")
plot_titles <- c("Exhaustion Score", "Effector Score", "Stemness Score")
ordered_plots <- list()
for(i in 1:length(score_names)){
  p <- VlnPlot(CD8, features = score_names[i], 
               pt.size = 0,
               cols = cell_color) + 
    geom_boxplot(width = 0.1, fill = "white", outlier.shape = NA) + 
    labs(title = plot_titles[i]) +
    theme_classic() 
  ordered_plots[[i]] <- p}
wrap_plots(ordered_plots, ncol = 3)

