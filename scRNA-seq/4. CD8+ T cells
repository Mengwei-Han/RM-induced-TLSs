# Annotations and clustering of CD8+ T cells
scRNA.harmony <- readRDS("scRNA.harmony.rds")
Idents(scRNA.harmony) <- "celltype"
CD8 <- subset(scRNA.harmony, idents = "CD8+ T")
CD8 <- NormalizeData(CD8) %>% FindVariableFeatures() %>% ScaleData() %>% RunPCA(verbose=FALSE)
CD8 <- FindNeighbors(CD8, reduction = "harmony", dims = 1:30)
CD8 <- FindClusters(CD8, resolution = 1.5)
CD8 <- RunUMAP(CD8, dims = 1:30, reduction = "harmony")

DefaultAssay(CD8) <- "RNA"
markers <- FindAllMarkers(object = CD8, test.use = "wilcox",
                         only.pos = T,
                         min.pct = 0.25,
                         logfc.threshold = 0.25)
all.markers <- markers %>% dplyr::select(gene,everything()) %>%subset(p_val<0.05)
top30 <- all.markers %>% group_by(cluster) %>% top_n(n=30,wt=avg_log2FC)

Idents(CD8) <- "seurat_clusters"
CD8_ID <- c("4"="ISG T","6"="ISG T","13"="ISG T",
            "11"="Tn","14"="NK-like T","5"="Temra",
            "10"="Temra","7"="Early Tem","0"="Tem",
            "9"="Tex-term", "2"="Tex-int", "8"="Tex-res",
            "16"="Tex-stem","15"="Cycling T","1"="Trm",
             "3"="Trm","17"="Early Tem","12"="Tex-res")

CD8 <- RenameIdents(CD8, CD8_ID)
CD8$celltype <- Idents(CD8)
target_order <- c("Tn", "Temra","Early Tem", "Tem","Tex-stem", "Tex","Tex-term",
                  "Tex-res","Trm","NK-like T","ISG T","Cycling T")
Idents(CD8)="celltype"
Idents(CD8) <- factor(Idents(CD8), levels = target_order)
CD8$celltype <- factor(CD8$celltype, levels = target_order)

# UMAP plot of CD8+ T cells showing identified clusters (Fig. 7a) ###################################################################
cell_color <- c( "#3AB7BC", "#2672A7","#ACD286", "#659E33", "#D3221E", "#C5AED0",
              "#D43080", "#633A8F", "#CD5D14", "#A2C7DB","#F3B970","#F09493")
DimPlot(CD8, reduction = "umap", pt.size = 0.5,cols=cell_color)

