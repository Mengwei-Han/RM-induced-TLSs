# Pseudotime trajectory of CD8+ T Cell Differentiation via Monocle3 (Fig. S7d) ######################################################
expression_matrix <- GetAssayData(CD8, assay = "RNA", slot = "counts")
cell_metadata <- CD8@meta.data
gene_annotation <- data.frame(gene_short_name = rownames(expression_matrix), row.names = rownames(expression_matrix))

cds <- new_cell_data_set(expression_matrix,
                         cell_metadata = cell_metadata,
                         gene_metadata = gene_annotation)
reducedDims(cds)[["UMAP"]] <- Embeddings(CD8, reduction = "umap")
cds@clusters$UMAP$partitions <- factor(rep(1, ncol(cds)), levels = 1)
names(cds@clusters$UMAP$partitions) <- colnames(cds)
cds@clusters$UMAP$clusters <- Idents(CD8)

cds_CD8 <- learn_graph(cds, 
                    use_partition = TRUE, 
                    close_loop = FALSE,
                    learn_graph_control = list(euclidean_distance_ratio = 5,
                                               geodesic_distance_ratio = 5))

plot_cells(cds_CD8, color_cells_by = "celltype", label_groups_by_cluster = FALSE,
           label_leaves = FALSE, label_branch_points = TRUE)
root_cells <- colnames(cds[, clusters(cds) == "Tn"])
cds_CD8 <- order_cells(cds_CD8, root_cells = root_cells)

p_celltype=plot_cells(cds_CD8, 
           color_cells_by = "celltype", 
           label_cell_groups = F, 
           label_leaves = F, 
           label_branch_points = F,
           graph_label_size = 0,
           cell_stroke = 0)+
  scale_color_manual(values = cell_color)

p_pseudotime=plot_cells(cds_CD8, 
           color_cells_by = "pseudotime", 
           label_cell_groups = F, 
           label_leaves = F, 
           label_branch_points = F,
           graph_label_size = 0,
           cell_stroke = 0)

# Pseudotime trajectory of Tex Differentiation via Monocle2 (Fig. 7f) ###############################################################
Idents(CD8) <- "celltype"
CD8_tex <- subset(CD8, idents = c("Tex-stem", "Tex-int", "Tex-term", "Tex-res"))

data <- as(as.matrix(CD8_tex@assays$RNA@counts), 'sparseMatrix')
pd <- new('AnnotatedDataFrame', data = CD8_tex@meta.data)
fData <- data.frame(gene_short_name = row.names(data), row.names = row.names(data))
fd <- new('AnnotatedDataFrame', data = fData)

cds_m2 <- newCellDataSet(data, phenoData = pd, featureData = fd, 
                         expressionFamily = negbinomial.size())

cds_m2 <- estimateSizeFactors(cds_m2)
cds_m2 <- estimateDispersions(cds_m2)  
diff_test_res <- differentialGeneTest(cds_m2, 
                                      fullModelFormulaStr = "~celltype", 
                                      cores = 4) 

ordering_genes <- row.names(subset(diff_test_res, qval < 0.01))
cds_m2 <- setOrderingFilter(cds_m2, ordering_genes)
cds_m2 <- reduceDimension(cds_m2, max_components = 2, method = 'DDRTree')
cds_m2 <- orderCells(cds_m2,root_state = 2)

color=c( "#D3221E", "#C5AED0","#D43080", "#633A8F")
p_celltype_Tex=plot_cell_trajectory(cds_m2, color_by = "celltype", cell_size = 1) +
  scale_color_manual(values = color) 
p_pseudotime_Tex=plot_cell_trajectory(cds_m2, color_by = "Pseudotime", cell_size = 1)+
  scale_color_viridis_c(option = "magma")

# Dynamic expression of genes along Tex differentiation pseudotime trajectory (Fig. 7g) #############################################
gene_groups <- list(
  Stemness = c("Ccr7", "Tcf7", "Sell"),
  Effector = c("Gzma", "Gzmb", "Prf1","Ltb"),
  Exhaustion = c("Pdcd1","Entpd1","Tigit"),
  Resident = c("Zfp683", "Itgae", "Itga1"))

all_target_genes <- unlist(gene_groups)

new_data <- data.frame(Pseudotime = seq(0, max(pData(cds_m2)$Pseudotime), length.out = 100))
curve_data <- genSmoothCurves(cds_m2[all_target_genes, ], 
                              new_data = new_data, 
                              cores = 1)

normalize_01 <- function(x) { 
  if(max(x) - min(x) == 0) return(x)
  (x - min(x)) / (max(x) - min(x)) 
}
curve_data_norm <- t(apply(curve_data, 1, normalize_01))

plot_df <- as.data.frame(t(curve_data_norm))
plot_df$Pseudotime <- new_data$Pseudotime
plot_data_long <- pivot_longer(plot_df, 
                               cols = -Pseudotime, 
                               names_to = "Gene", 
                               values_to = "Normalized_Expression")

group_map <- data.frame(
  Gene = unlist(gene_groups),
  Group = rep(names(gene_groups), times = sapply(gene_groups, length))
)
plot_data_long <- merge(plot_data_long, group_map, by = "Gene")
plot_data_long$Group <- factor(plot_data_long$Group, levels = names(gene_groups))

ggplot(plot_data_long, aes(x = Pseudotime, y = Normalized_Expression, color = Gene)) +
  geom_line(size = 1.2, alpha = 0.8) +
  facet_wrap(~Group, ncol = 2) + 
  scale_color_viridis_d(option = "turbo") + 
  labs(x = "Pseudotime (Stem-like -> Tex)", 
       y = "Normalized Expression (0-1)") +
  theme_classic() +
  theme(panel.grid = element_blank(),
        strip.background = element_blank(), 
        strip.text = element_text(size = 14, face = "bold"),
        axis.text = element_text(color = "black"),
        legend.text = element_text(size = 8)) 

# Heatmap showing the differentially expressed genes in R@MP group compared to the control (Fig. S7e) ###############################
Idents(CD8) <- "orig.ident"
deg <- FindMarkers(
  object = CD8, 
  ident.1 = "RMP", 
  ident.2 = "C", 
  logfc.threshold = 0,   
  min.pct = 0.01         
)

deg$gene <- rownames(deg)
deg$change <- "Stable"
deg$change[deg$avg_log2FC > log2(1.2) &deg$p_val < 0.05] <- "Up"
deg$change[deg$avg_log2FC < -log2(1.2) & deg$p_val < 0.05] <- "Down"
up_count <- sum(deg$change == "Up")
down_count <- sum(deg$change == "Down")
up <- deg %>% filter(change == "Up")
down <- deg %>% filter(change == "Down") 
plot_genes <- c(up$gene, down$gene)

avg_results <- AverageExpression(CD8, 
                             group.by = "orig.ident", 
                             features = plot_genes, 
                             slot = "data") %>% as.data.frame()
avg_exp <- as.data.frame(avg_results$RNA)
target_cols <- c("RNA.C", "RNA.MP", "RNA.RM", "RNA.RMP")
avg_exp <- avg_exp[plot_genes, target_cols]
scaled_matrix <- t(scale(t(avg_exp)))

Heatmap(scaled_matrix,  
        col = colorRamp2(c(-2, 0, 2), c("blue4", "white", "red3")),
        cluster_rows = TRUE,
        cluster_columns = FALSE,    
        show_row_names = TRUE, 
        row_names_gp = gpar(fontsize = 8),
        column_names_gp = gpar(fontsize = 12, fontface = "bold"),
        row_split = factor(c(rep("Up-regulated", nrow(up)), 
                             rep("Down-regulated", nrow(down))),
                           levels = c("Up-regulated", "Down-regulated")))
