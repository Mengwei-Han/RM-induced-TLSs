# 数据归一化、转换和过滤
data <- read_excel("gene expression.xlsx", col_names = TRUE) %>% column_to_rownames(var = "GeneSymbol")
fpkm_to_tpm <- function(fpkm) {return(exp(log(fpkm) - log(sum(fpkm)) + log(1e6)))}
tpms <- apply(data, 2, fpkm_to_tpm)

expr.TPM=normalizeBetweenArrays(tpms)
expr.TPM=log2(expr.TPM+1)
expr.TPM=as.data.frame(expr.TPM)
expr.TPM=filter(expr.TPM,rowMeans(expr.TPM[,1:4])>1|rowMeans(expr.TPM[,5:8])>1|rowMeans(expr.TPM[,9:12])>1|rowMeans(expr.TPM[,13:16])>1)

# Fig. 4b
# PCA分析给四组
samples <- colnames(expr.TPM)
groups <- c(rep("C", 4), rep("M", 4), rep("R", 4), rep("RM", 4))
groups <- factor(groups, levels = c("C", "M", "R", "RM"))

expr_scaled <- t(expr.TPM)
gene_var <- apply(expr_scaled, 2, var)
constant_genes <- sum(gene_var == 0)
if(constant_genes > 0) {
  expr_filtered <- expr_scaled[, gene_var > 0]
  cat("Removed", constant_genes, "constant genes")
} else {
  expr_filtered <-expr_scaled
}
expr_scaled <- scale(expr_filtered)

pca_result <- prcomp(expr_scaled, center = FALSE, scale. = FALSE)
variance_explained <- (pca_result$sdev^2 / sum(pca_result$sdev^2)) * 100
pca_scores <- as.data.frame(pca_result$x)
pca_scores$Group <- groups
pca_scores$Sample <- samples

plot_PCA <- ggplot(pca_scores, aes(x = PC1, y = PC2, color = Group, label = Sample)) +
  geom_point(size = 4) +
  geom_mark_ellipse(
    aes(fill = Group,color=Group),
    alpha = 0.05,  # 填充透明度
    expand = unit(1, "mm"),  # 椭圆扩展范围
    show.legend = FALSE  # 避免图例重复
  ) +
  theme_bw() +theme(panel.grid = element_blank()) +
  labs(title = "PCA Plot",
       x = paste0("PC1 (", round(variance_explained[1], 1), "%)"),
       y = paste0("PC2 (", round(variance_explained[2], 1), "%)")) +
  scale_color_manual(values = c("C" = "grey40","M" = "darkorange4", "R" = "dodgerblue4", "RM" = "palegreen4"))+
  scale_fill_manual(values = c("C" = "grey40","M" = "darkorange4", "R" = "dodgerblue4", "RM" = "palegreen4"))+
  xlim(-170, 190) + 
  ylim(-70, 130)

# Fig. S4a
#C vs M
CM=samples[groups %in% c("M", "C")]
CM_expr <- expr.TPM[, CM]
CM_groups <- groups[groups %in% c("M", "C")]
CM_groups <- factor(CM_groups)
CM_groups <- relevel(CM_groups, ref = "C")
CM_design <- model.matrix(~CM_groups)
colnames(CM_design) <- levels(CM_groups)
rownames(CM_design) <- colnames(CM_expr)

CM_fit <- lmFit(CM_expr, CM_design)
CM_fit <- eBayes(CM_fit)
CM_Dif <- topTable(CM_fit, coef = 2, adjust = "fdr", number = Inf)

CM_Dif$significant <- "stable"
CM_Dif$significant[CM_Dif$logFC >= log2(1.5) & CM_Dif$P.Value < 0.05] <- "up"
CM_Dif$significant[CM_Dif$logFC <= (-log2(1.5)) & CM_Dif$P.Value < 0.05] <- "down"
sum(CM_Dif$significant=="down")

p_CM=ggplot(CM_Dif,aes(logFC,-1*log10(P.Value)))+
  xlim(-3,3)+ylim(0,5)+geom_point(aes(color=significant),size=1.5)+
  theme_classic()+scale_color_manual(values = c("black","grey","darkorange4"))+
  geom_hline(yintercept = -1*log10(0.05),linetype=4,linewidth=1)+
  geom_vline(xintercept = c(-log2(1.5),log2(1.5)),linetype=4,size=1)+
  annotate("text",x=2,y=4,label="(234)",colour="darkorange4")+
  annotate("text",x=-2,y=4,label="(357)",colour="black")

