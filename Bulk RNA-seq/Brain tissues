# 检查基因签名中的基因在表达矩阵中的存在情况
expr_matrix <- as.matrix(expr.TPM)
check_gene_coverage <- function(expr_matrix, gene_sets) {
  for (set_name in names(gene_sets)) {
    genes_in_set <- gene_sets[[set_name]]
    genes_in_matrix <- genes_in_set[genes_in_set %in% rownames(expr_matrix)]
    coverage <- length(genes_in_matrix) / length(genes_in_set)
    cat(paste0("Signature '", set_name, "': ", 
               length(genes_in_matrix), "/", length(genes_in_set),
               " genes found (", round(coverage * 100, 1), "%)\n"))
  }
}

